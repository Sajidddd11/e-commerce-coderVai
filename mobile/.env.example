# ── Medusa backend ──────────────────────────────────────────────────────
EXPO_PUBLIC_MEDUSA_BACKEND_URL=https://api.zahan.net
EXPO_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxxxxxxx

# ── Region / locale ─────────────────────────────────────────────────────
# ISO-2 lowercase, matches web NEXT_PUBLIC_DEFAULT_REGION
EXPO_PUBLIC_DEFAULT_REGION=bd

# ── Payments ────────────────────────────────────────────────────────────
# Backend uses SSLCommerz (cards, bKash, Nagad) + Cash on Delivery only.
# No client keys needed — SSLCommerz store credentials live on the backend.

# ── Meta / Facebook (matches web fb:app_id + Pixel ID) ──────────────────
EXPO_PUBLIC_FACEBOOK_PIXEL_ID=868788322534380
EXPO_PUBLIC_FACEBOOK_APP_ID=868788322534380

# ── Deep linking (SSLCommerz return + order/product links) ──────────────
EXPO_PUBLIC_APP_SCHEME=zahan
EXPO_PUBLIC_APP_BUNDLE_ID=com.zahan.store

# ── Storefront URL (share links / OG fallbacks) ─────────────────────────
EXPO_PUBLIC_STOREFRONT_URL=https://zahan.com.bd

# ── WhatsApp support (matches web wa.me link) ───────────────────────────
EXPO_PUBLIC_WHATSAPP_NUMBER=8801304117711
