{
  "name": "demo-clothing-store",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "postbuild": "node scripts/postbuild-copy-admin.js",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "cross-env NODE_ENV=production medusa start",
    "start:local": "cross-env NODE_ENV=staging medusa start",
    "dev": "medusa develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@getbrevo/brevo": "^5.0.4",
    "@medusajs/admin-sdk": "2.11.3",
    "@medusajs/cache-redis": "^2.11.3",
    "@medusajs/cli": "2.11.3",
    "@medusajs/framework": "2.11.3",
    "@medusajs/index": "^2.11.3",
    "@medusajs/medusa": "2.11.3",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@types/formidable": "^3.4.6",
    "@types/nodemailer": "^8.0.0",
    "@upstash/redis": "^1.35.6",
    "axios": "^1.13.5",
    "dotenv": "^17.4.2",
    "formidable": "^3.5.4",
    "ioredis": "^5.8.2",
    "nodemailer": "^8.0.7",
    "react-markdown": "^10.1.0",
    "sharp": "^0.34.5",
    "sslcommerz-lts": "^1.2.0",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.11.3",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
